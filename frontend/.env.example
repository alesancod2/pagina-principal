# =============================================
# Frontend - Variaveis de Ambiente
# =============================================

# URL da API Backend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Google Maps API Key (para geolocalizacao)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=sua_google_maps_api_key

# Nome da aplicacao
NEXT_PUBLIC_APP_NAME=Auto Vale Prevencoes

# URL do Storage (Cloudflare R2 public bucket)
NEXT_PUBLIC_STORAGE_URL=https://pub-autovale.r2.dev

# Ambiente
NODE_ENV=development
