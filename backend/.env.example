# =============================================
# Backend - Variaveis de Ambiente
# =============================================

# Banco de Dados PostgreSQL (Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# JWT
JWT_SECRET=sua_chave_secreta_jwt_aqui
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# API AEasy (Integracao)
AEASY_API_TOKEN=seu_token_aeasy_aqui
AEASY_API_URL=https://api.aeasy.io/v2

# Redis (Upstash)
REDIS_URL=redis://default:[PASSWORD]@[HOST].upstash.io:6379

# Google Maps API Key
GOOGLE_MAPS_API_KEY=sua_google_maps_api_key

# Cloudflare R2 Storage
CLOUDFLARE_R2_ACCESS_KEY_ID=seu_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=seu_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=autovale-assets
CLOUDFLARE_R2_ENDPOINT=https://[ACCOUNT_ID].r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://pub-autovale.r2.dev

# URL do Frontend (CORS)
FRONTEND_URL=http://localhost:3000

# Porta do servidor
PORT=3001

# Ambiente
NODE_ENV=development
